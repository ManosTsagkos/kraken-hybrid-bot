# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file to git or share it with anyone.

# --- Kraken API credentials ---
# Create at: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query Open/Closed Orders, Create & Modify Orders,
#                        Cancel/Close Orders, Query Open Positions
# Do NOT enable "Withdraw Funds" on this key.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- News API (for geopolitical / IPO keyword scoring) ---
# Free tier available at https://newsapi.org/ (developer plan has request limits
# and a delay on free tier - check current terms before relying on it for live trading)
NEWSAPI_KEY=

# --- Safety switches ---
# Keep this as "true" until you have manually verified behaviour over many days/weeks.
# When true, every order is sent to Kraken with validate=true (Kraken checks it but
# NEVER executes it / never returns a real order id). This is Kraken's own built-in
# dry-run mechanism - see https://support.kraken.com/articles/advanced-api-faq
DRY_RUN=true
